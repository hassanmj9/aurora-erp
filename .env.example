# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aurora_erp"
DIRECT_URL="postgresql://user:password@localhost:5432/aurora_erp"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-url.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Shopify Integration
SHOPIFY_API_KEY="your-shopify-api-key"
SHOPIFY_API_SECRET="your-shopify-api-secret"
SHOPIFY_STORE_URL="your-store.myshopify.com"
SHOPIFY_WEBHOOK_SECRET="your-webhook-secret"

# Shipping - DHL
DHL_API_KEY="your-dhl-api-key"
DHL_API_SECRET="your-dhl-api-secret"

# CRM - Kommo (formerly amoCRM)
KOMMO_API_KEY="your-kommo-api-key"
KOMMO_SUBDOMAIN="your-kommo-subdomain"

# Payment Methods
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
AFFIRM_API_KEY="your-affirm-api-key"

# International Transfer
WISE_API_KEY="your-wise-api-key"

# Node Environment
NODE_ENV="development"
